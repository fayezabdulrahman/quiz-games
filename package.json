{
  "name": "one-percent-club",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"node --watch server/index.js\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "build": "vite build",
    "db:generate": "drizzle-kit generate",
    "db:check": "node server/db/checkSchema.js",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node server/db/seed.js",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint .",
    "lint:biome": "biome lint .",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "@clerk/express": "^2.1.33",
    "@clerk/react": "^6.11.2",
    "@neondatabase/serverless": "^1.1.0",
    "@vitejs/plugin-react": "^4.7.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^6.30.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "vite": "^6.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@eslint/js": "^9.39.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0"
  }
}

# Local development uses Vite's /socket.io proxy when this is left empty.
# On Vercel, set this to the public URL of the Render web service.
VITE_SOCKET_URL=https://your-service-name.onrender.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# On Render, set this to the Vercel production URL.
# Comma-separate multiple origins if preview deployments also need access.
CLIENT_ORIGIN=https://your-project.vercel.app
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Neon Postgres connection string.
# Required on Render for backend DB access and locally when running Drizzle commands.
# Do not expose this in Vercel frontend environment variables.
DATABASE_URL=DB_URL_here
